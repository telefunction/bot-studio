{
  "name": "bot-studio",
  "version": "1.4.1",
  "private": true,
  "description": "A browser-based Telegram Bot API workspace for exploring methods, building request payloads, and sending test calls.",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telefunction/bot-studio.git"
  },
  "homepage": "https://telefunction.github.io/bot-studio/",
  "bugs": {
    "url": "https://github.com/telefunction/bot-studio/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "node --check scripts/lib/entities.mjs && node --check scripts/lib/schema-constraints.mjs && node --check scripts/update-telegram-schema.mjs && node --check scripts/normalize-schema.mjs && node scripts/validate-project.mjs && vue-tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "schema:normalize": "node scripts/normalize-schema.mjs",
    "schema:update": "node scripts/update-telegram-schema.mjs",
    "schema:check": "node scripts/update-telegram-schema.mjs --check",
    "validate": "node scripts/validate-project.mjs",
    "validate:pages": "node scripts/validate-project.mjs --docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "fix": "npm run format && npm run lint:fix"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "lucide-vue-next": "^0.468.0",
    "vite": "^6.0.7",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "postcss": "^8.4.49",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0",
    "vue-tsc": "^2.2.0"
  }
}
