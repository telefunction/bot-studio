{
  "name": "bot-studio",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "node --check scripts/update-telegram-schema.mjs && node --check scripts/normalize-schema.mjs && node scripts/validate-project.mjs && vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "schema:normalize": "node scripts/normalize-schema.mjs",
    "schema:update": "node scripts/update-telegram-schema.mjs",
    "schema:check": "node scripts/update-telegram-schema.mjs --check",
    "validate": "node scripts/validate-project.mjs",
    "validate:pages": "node scripts/validate-project.mjs --docs"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "lucide-vue-next": "^0.468.0",
    "vite": "^6.0.7",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vue-tsc": "^2.2.0"
  }
}
